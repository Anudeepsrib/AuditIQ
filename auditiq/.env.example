# ── AuditIQ Environment Variables ────────────────────────────
# Copy this file to .env and update values for your environment.

# App
APP_NAME=AuditIQ
APP_VERSION=0.1.0
DEBUG=false

# Database
DATABASE_URL=sqlite:///./auditiq.db

# JWT (CHANGE THIS IN PRODUCTION!)
JWT_SECRET_KEY=CHANGE-ME-TO-A-RANDOM-64-CHAR-STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_REGISTRY_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=auditiq-finetune

# Model / Inference
MODEL_MAX_INPUT_TOKENS=8000
DEFAULT_MODEL_NAME=auditiq-extractor

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Seed Admin (CHANGE IN PRODUCTION!)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=AdminPassword123!
SEED_ADMIN_EMAIL=admin@auditiq.local
